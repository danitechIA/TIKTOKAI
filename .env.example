# ===== TikTokAI - Orquestador de edición de vídeo =====
# Copia este fichero a .env y rellena tus valores reales.

# API de Groq (crea una key gratuita en https://console.groq.com/keys)
GROQ_API_KEY=gsk_tu_api_key_aqui

# Modelo de transcripción (Whisper en Groq)
TRANSCRIBE_MODEL=whisper-large-v3

# Modelo de chat para generar copy/hashtags
CAPTION_MODEL=llama-3.1-8b-instant

# Servidor
HOST=0.0.0.0
PORT=8080

# Contraseña de acceso a la interfaz (vacío = sin contraseña)
APP_PASSWORD=cambia_esta_contrasena

# Idioma por defecto de los vídeos (es / en / auto)
DEFAULT_LANGUAGE=es
